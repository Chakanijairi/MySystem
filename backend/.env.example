# --- Supabase (Settings → Database → Connection string → URI) ---
# Long-running Node (Render): prefer "Direct connection" (port 5432) OR Transaction pooler (6543).
# The app appends ?pgbouncer=true automatically for pooler hosts.
# Use the password from Supabase (Database settings), not your Supabase account password.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# If SSL fails, try: DATABASE_SSL_REJECT_UNAUTHORIZED=false (default is permissive for Supabase)
# If you still get 500s on login, use Supabase "Direct connection" (port 5432) instead of the pooler (6543).

# --- JWT (set in Render → Environment for stable sessions; if omitted, server generates one per run) ---
JWT_SECRET=use-a-long-random-string-at-least-32-characters

JWT_EXPIRES_IN=7d
PORT=5000

# --- CORS: your Vercel site(s), comma-separated. https:// recommended. ---
# Any https://*.vercel.app is allowed unless CORS_ALLOW_VERCEL=false
FRONTEND_ORIGIN=http://localhost:5173
# CORS_ALLOW_VERCEL=false

# Optional: force SSL for pg (Supabase: usually not needed)
# DATABASE_SSL=true

# Admin seed (run db:init locally against Supabase URL)
ADMIN_EMAIL=shaw
ADMIN_PASSWORD=123
ADMIN_FULL_NAME=Shaw
