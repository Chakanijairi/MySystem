# --- Supabase (Settings → Database → Connection string → URI) ---
# Use "Session" or "Transaction" pooler URI; include password.
# DATABASE_SSL is auto-enabled for Supabase; set DATABASE_SSL=false only for local Postgres.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# --- JWT (set in Render → Environment for stable sessions; if omitted, server generates one per run) ---
JWT_SECRET=use-a-long-random-string-at-least-32-characters

JWT_EXPIRES_IN=7d
PORT=5000

# --- CORS: your Vercel site(s), comma-separated. No trailing slash. ---
# Example: https://myapp.vercel.app,https://myapp-git-main-xyz.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# Optional: force SSL for pg (Supabase: usually not needed)
# DATABASE_SSL=true

# Admin seed (run db:init locally against Supabase URL)
ADMIN_EMAIL=shaw
ADMIN_PASSWORD=123
ADMIN_FULL_NAME=Shaw
