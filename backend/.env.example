# --- PostgreSQL (pick one) ---
# Typical local Windows/macOS (pgAdmin / default superuser "postgres"):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dealer_monitoring
# Docker (from repo root: docker compose up -d) — user pern matches docker-compose.yml:
# DATABASE_URL=postgresql://pern:pern@localhost:5432/dealer_monitoring
# If you see "password authentication failed", put YOUR real password after postgres:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/dealer_monitoring
# Cloud (Neon, Supabase, etc.): paste the connection string URL, then:
# DATABASE_SSL=true

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# Run npm run db:init after DB is up. Seeds / updates admin (stored in users.email):
ADMIN_EMAIL=shaw
ADMIN_PASSWORD=123
ADMIN_FULL_NAME=Shaw
