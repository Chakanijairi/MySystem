# =============================================================================
# pgAdmin / local PostgreSQL (Windows)
# =============================================================================
# 1. Start PostgreSQL (Services) and open pgAdmin.
# 2. Register server if needed: host localhost, port 5432, user often "postgres",
#    password = what you set during PostgreSQL install.
# 3. Create database: right‑click "Databases" → Create → Database → name: dealer_monitoring
#    OR run backend/db/create-database.sql in Query Tool (connected to postgres DB).
# 4. Set DATABASE_URL below (replace YOUR_PASSWORD; use URL-encoding for @ # % etc. in password).
# 5. Copy this file to .env and set DATABASE_URL. Then: npm run db:test && npm run db:init && npm run dev
#
# --- Use ONE of the following DATABASE_URL lines (local OR cloud) ---

# Local PostgreSQL (pgAdmin) — no SSL on localhost
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/dealer_monitoring
DATABASE_SSL=false

# Supabase (comment out the two lines above and uncomment one line below)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Long-running Node (Render): prefer "Direct connection" (port 5432) OR Transaction pooler (6543).
# If SSL fails: DATABASE_SSL_REJECT_UNAUTHORIZED=false. If login still fails, try Direct connection :5432.

# Tables are created automatically on deploy (AUTO_DB_SETUP defaults on). Set AUTO_DB_SETUP=false to disable.
# ADMIN_EMAIL / ADMIN_PASSWORD must be set on Render so the admin user is created on first boot.

# --- JWT (set in Render → Environment for stable sessions; if omitted, server generates one per run) ---
JWT_SECRET=use-a-long-random-string-at-least-32-characters

JWT_EXPIRES_IN=7d
PORT=5000

# --- CORS: your Vercel site(s), comma-separated. https:// recommended. ---
# Any https://*.vercel.app is allowed unless CORS_ALLOW_VERCEL=false
FRONTEND_ORIGIN=http://localhost:5173
# CORS_ALLOW_VERCEL=false

# Optional: force SSL for pg (Supabase: usually not needed)
# DATABASE_SSL=true

# Admin seed (npm run db:init uses DATABASE_URL above)
ADMIN_EMAIL=chawkanijairi8@gmail.com
ADMIN_PASSWORD=shaw
ADMIN_FULL_NAME=Shaw

# =============================================================================
# Gmail SMTP — sends the password-reset OTP email.
# =============================================================================
# 1) Turn on 2-Step Verification on your Google account:
#      https://myaccount.google.com/security
# 2) Create a Gmail "App password" (16 chars):
#      https://myaccount.google.com/apppasswords
#    Choose "Mail" / device "Other (Custom name)" → name it "Personal Collection".
# 3) Paste the App password below as SMTP_PASS (spaces are fine, they get stripped).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=
SMTP_FROM=Personal Collection <your-gmail@gmail.com>
